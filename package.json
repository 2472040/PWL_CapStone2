{
  "name": "loka-lab-inventory",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "server": "node server/server.js",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "seed": "node server/seeders/seed.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo:all",
    "build": "vite build",
    "preview": "vite preview",
    "security-test": "node server/tests/security.test.cjs",
    "lint": "eslint \"**/*.{js,jsx,cjs,mjs}\"",
    "lint:fix": "eslint \"**/*.{js,jsx,cjs,mjs}\" --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@studio-freight/lenis": "^1.0.42",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "framer-motion": "^12.39.0",
    "gsap": "^3.12.5",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "jsqr": "^1.4.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.16.0",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "pdfmake": "^0.3.9",
    "pug": "^3.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0",
    "sequelize": "^6.37.8",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "unicornstudio-react": "^2.1.9",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.4",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.7"
  }
}
