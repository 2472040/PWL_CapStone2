{
  "name": "loka-lab-inventory-monorepo",
  "private": true,
  "version": "3.0.0",
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:frontend": "npm run dev --workspace=@loka/frontend",
    "dev:backend": "npm run dev --workspace=@loka/backend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "npm run build --workspace=@loka/frontend",
    "build:backend": "npm run build --workspace=@loka/backend",
    "build": "npm run build:backend && npm run build:frontend",
    "test:frontend": "npm run test --workspace=@loka/frontend",
    "test:backend": "npm run test --workspace=@loka/backend",
    "test:all": "npm run test:backend && npm run test:frontend",
    "security-test": "npm run security-test --workspace=@loka/backend",
    "lint": "eslint \"apps/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"apps/**/*.{js,jsx,ts,tsx}\" --fix",
    "format": "prettier --write \"apps/**/*.{js,jsx,ts,tsx,json,css,md}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"apps/**/*.{js,jsx,ts,tsx,json,css,md}\" \"tests/**/*.ts\"",
    "db:migrate": "npm run db:migrate --workspace=@loka/backend",
    "db:migrate:undo": "npm run db:migrate:undo --workspace=@loka/backend",
    "seed": "npm run seed --workspace=@loka/backend",
    "e2e:test": "npx playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.61.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "uuid": "^11.0.0",
    "glob": "^13.0.6"
  }
}
