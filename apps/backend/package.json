{
  "name": "@loka/backend",
  "private": true,
  "version": "3.0.0",
  "main": "dist-server/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist-server/server.js",
    "dev": "tsc && node dist-server/server.js",
    "seed": "node dist-server/seeders/seed.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo:all",
    "test": "vitest run",
    "test:watch": "vitest",
    "security-test": "vitest run tests/security.test.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "pdfmake": "^0.3.9",
    "pug": "^3.0.4",
    "sequelize": "^6.37.8",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
