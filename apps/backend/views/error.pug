extends layout

block content
  style.
    .error-page {
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      min-height: 100vh; text-align: center; padding: 40px;
    }
    .error-page h1 { font-size: 48px; margin-bottom: 16px; }
    .error-page p { color: #71717a; font-size: 16px; margin-bottom: 24px; }
    .error-page a {
      padding: 12px 24px; background: rgba(255,255,255,0.1);
      border-radius: 12px; color: #b794ff; text-decoration: none;
    }

  .error-page
    h1 Oops!
    p= message || 'Halaman tidak ditemukan.'
    a(href="/") ← Kembali ke beranda
