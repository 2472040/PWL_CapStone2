extends layout

block content
  style.
    .print-page {
      background: #fff;
      color: #000;
      padding: 40px;
      max-width: 800px;
      margin: 0 auto;
    }
    .label-card {
      border: 2px solid #000;
      border-radius: 8px;
      padding: 24px;
      margin-bottom: 24px;
      page-break-inside: avoid;
    }
    .label-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 16px;
      border-bottom: 1px solid #ccc;
      padding-bottom: 12px;
    }
    .label-header h2 { font-size: 18px; }
    .label-header .code { font-size: 24px; font-weight: 700; font-family: monospace; }
    .label-info { display: grid; grid-template-columns: 120px 1fr; gap: 8px; font-size: 14px; }
    .label-info dt { font-weight: 600; color: #555; }
    .label-info dd { color: #000; }
    .qr-placeholder {
      width: 120px; height: 120px;
      border: 1px solid #ccc;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; color: #999; text-align: center;
    }
    .print-btn {
      display: block;
      margin: 20px auto;
      padding: 12px 32px;
      background: #000;
      color: #fff;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
    }
    @media print {
      .print-btn { display: none; }
      body { background: #fff; }
    }

  .print-page
    button.print-btn(onclick="window.print()") 🖨️ Cetak Label

    .label-card
      .label-header
        div
          h2= item.name
          p= item.category
        .code= item.code

      div(style="display: flex; gap: 24px;")
        .qr-placeholder
          if label.qr_data
            | QR: #{label.qr_data}
          else
            | QR belum dibuat
        dl.label-info
          dt Serial
          dd= item.serial || '-'
          dt Label No
          dd= label.label_number || '-'
          dt Spesifikasi
          dd= item.specs || '-'

    button.print-btn(onclick="window.print()") 🖨️ Cetak Label
