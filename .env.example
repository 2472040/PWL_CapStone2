# Database Settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=lokalab_user
DB_PASS=lokalab_password
DB_NAME=lokalab_db

# JWT Security Keys (Use secure random strings in production)
JWT_SECRET=your-super-secure-jwt-access-secret-key
JWT_REFRESH_SECRET=your-super-secure-jwt-refresh-secret-key
JWT_EXPIRES_IN=7d

# Application Configuration
PORT=3000
NODE_ENV=development

# Encryption Secrets (Must be 32-byte hex string / 64 characters)
# e.g., generated with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKUP_ENCRYPTION_SECRET=your-32-byte-hex-secret-for-backups
AUDIT_LOG_SECRET=your-32-byte-hex-secret-for-audit-logs
